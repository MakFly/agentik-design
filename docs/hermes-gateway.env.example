# ── Hermes Gateway — Telegram + Discord ──────────────────────────────────────
# Copy the filled values into ~/.hermes/.env, then run:  hermes gateway
# (or `hermes gateway install` to run it as a background service at boot).
#
# This connects ONE Hermes agent to BOTH platforms at once. To make TWO bots
# CONVERSE with each other, see the Agentik relay below (scripts/bot-relay.ts):
# Hermes handles platform connectivity; Agentik orchestrates the A⇄B exchange.

# ── Telegram ─────────────────────────────────────────────────────────────────
# 1) Talk to @BotFather → /newbot → copy the token.
# 2) Your numeric user id: message @userinfobot.
# 3) For groups: @BotFather /setprivacy → Disable (so the bot sees messages).
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_ALLOWED_USERS=<your_numeric_user_id>
# TELEGRAM_HOME_CHANNEL=<chat_id_for_scheduled_results>

# ── Discord ──────────────────────────────────────────────────────────────────
# 1) https://discord.com/developers/applications → New Application → Bot → Reset Token.
# 2) Bot page → enable BOTH: "Server Members Intent" + "Message Content Intent".
# 3) Invite: https://discord.com/oauth2/authorize?client_id=<APP_ID>&scope=bot+applications.commands&permissions=274878286912
DISCORD_BOT_TOKEN=<your_discord_bot_token>
DISCORD_ALLOWED_USERS=<your_discord_user_id>
# DISCORD_REQUIRE_MENTION=true              # require @mention in server channels
# DISCORD_FREE_RESPONSE_CHANNELS=<channel_id>   # channels where it answers without mention

# ── Inference provider (required for the agent to actually reply) ────────────
# Pick ONE. Without this, runs fail with "No inference provider configured".
# OPENROUTER_API_KEY=sk-or-...            # one key → many models (recommended)
# or run `hermes model` to log into Nous Portal / Codex (OAuth, no key)
