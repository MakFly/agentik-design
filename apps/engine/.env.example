# Engine HTTP port (Next.js rewrites /api/* here in dev)
PORT=8787

# Postgres — dev: shared infra (infra-postgres / localhost:5432).
# Shared infra runs with user/pass `test`/`test`; the `agentik` DB is created by
# `make install` (db/create). Override the URL if you run your own Postgres.
DATABASE_URL=postgresql://test:test@localhost:5432/agentik

# Redis — dev: shared infra (infra-redis / localhost:6379), used by BullMQ
REDIS_URL=redis://localhost:6379

# API rate limit — max authenticated requests per team per window (fixed window).
# Protects the shared control plane from a single tenant/bug saturating it.
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW_MS=60000

# Provider API keys — presence drives the Settings "OpenAI/Anthropic/Google key"
# capability pills. OPTIONAL: the CLI runtimes (claude, hermes, codex) authenticate
# via their own session, so they need NO key here. Set these only if you use the
# raw provider API (OpenAI agent node, or a future openai/anthropic runtime).
# NOTE: OPENAI_API_KEY is intentionally duplicated with apps/web/.env.local — the
# web chat routes and the engine's OpenAI node each load it from their own app.
# Keep the two values in sync if you use both.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Secret used to derive the AES-256 key encrypting stored credentials at rest.
# >=16 chars. If unset the engine boots with a loud warning and a weak default —
# set a real value before storing any credential.
CREDENTIALS_ENCRYPTION_KEY=

# Public base URLs — used to build the Google OAuth redirect URI and return target.
ENGINE_PUBLIC_URL=http://localhost:8787
WEB_PUBLIC_URL=http://localhost:3333

# Telegram local polling responsiveness. 500ms feels close to instant in dev.
TELEGRAM_POLL_INTERVAL_MS=500

# Cron scheduler for schedule-kind signals. Off unless "true" (avoids surprise fires).
SCHEDULER_ENABLED=false

# Dev email (run simulator "sends" here). Defaults target the shared infra-mailpit.
SMTP_HOST=localhost
SMTP_PORT=1025
# Mailbox the SMB seeder uses ("Gmail" in dev is Mailpit).
SEED_OPERATOR_EMAIL=kev.aubree@gmail.com

# Gmail sending needs NO env var: connect a Google account in the app
# (Settings → Connections). Once connected, that team's email sends through the real
# Gmail API; otherwise it falls back to infra-mailpit. See docs/gmail-oauth-setup.md.

# Dev only: allow the x-team/x-role header fallback when there is no session cookie.
# Set to "false" in production so unauthenticated requests are rejected.
AUTH_DEV_HEADERS=true

# Agent-execution harness (daemon). DAEMON_ENABLED gates the /daemon protocol;
# DAEMON_AUTH_TOKEN (>=16 chars) is the shared Bearer secret the daemon uses.
DAEMON_ENABLED=false
DAEMON_AUTH_TOKEN=dev-daemon-token-change-me-please

### Intégrations optionnelles ###
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
