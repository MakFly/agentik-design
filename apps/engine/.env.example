# Engine HTTP port (Next.js rewrites /api/* here in dev)
PORT=8787

# Postgres — dev: shared infra (infra-postgres / localhost:5432).
# Shared infra runs with user/pass `test`/`test`; the `agentik` DB is created by
# `make install` (db/create). Override the URL if you run your own Postgres.
DATABASE_URL=postgresql://test:test@localhost:5432/agentik

# Redis — dev: shared infra (infra-redis / localhost:6379), used by BullMQ
REDIS_URL=redis://localhost:6379

# Provider API keys — presence drives the Settings "OpenAI/Anthropic/Google key"
# capability pills. OPTIONAL: the CLI runtimes (claude, hermes, codex) authenticate
# via their own session, so they need NO key here. Set these only if you use the
# raw provider API (OpenAI agent node, or a future openai/anthropic runtime).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Agent-execution harness (daemon). DAEMON_ENABLED gates the /daemon protocol;
# DAEMON_AUTH_TOKEN (>=16 chars) is the shared Bearer secret the daemon uses.
DAEMON_ENABLED=false
DAEMON_AUTH_TOKEN=dev-daemon-token-change-me-please

### Intégrations optionnelles ###
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=