    "connect:gmail:oauth": "bun run scripts/connect-gmail-oauth.ts",
    "seed:gmail-skill": "bun run scripts/seed-gmail-skill.ts",
    "chat:clear": "bun run scripts/clear-chat-sessions.ts"
