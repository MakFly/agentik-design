{
  "name": "@agentik/engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/main.ts",
    "start": "bun run src/main.ts",
    "worker": "bun run src/execution/worker/worker.ts",
    "worker:dev": "bun run --watch src/execution/worker/worker.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@agentik/workflow-engine": "workspace:*",
    "@agentik/workflow-schema": "workspace:*",
    "@ai-sdk/anthropic": "^3",
    "@ai-sdk/google": "^3",
    "@ai-sdk/openai": "^3",
    "@ai-sdk/openai-compatible": "^1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "ai": "^6",
    "bullmq": "^5.34.0",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.6.14",
    "ioredis": "^5.4.2",
    "postgres": "^3.4.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5"
  }
}
