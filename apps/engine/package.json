    "@ai-sdk/google": "^3",
    "@ai-sdk/openai": "^3",
    "@ai-sdk/openai-compatible": "^1",
    "@electric-sql/pglite": "^0.5.3",
    "@modelcontextprotocol/sdk": "1.29.0",
    "ai": "^6",
    "bullmq": "^5.34.0",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.6.14",
    "ioredis": "^5.4.2",
    "postgres": "^3.4.5",
    "zod": "^4.4.3"
