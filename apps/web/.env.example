# ── Web app (Next.js) ────────────────────────────────────────────────────────
# Copied to .env.local by `make install` (only if .env.local doesn't exist yet).
# Next.js loads .env.local automatically in dev.

# ── LLM providers ────────────────────────────────────────────────────────────
# Used by the in-app chat/builder routes (app/api/v1/hermes-lite/*) and the
# provider registry (lib/llm/registry.ts). Set the key(s) for the provider(s)
# you actually use — a provider shows as "usable" as soon as one of its keys is set.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
XAI_API_KEY=
GROQ_API_KEY=

# ── Engine wiring (optional) ─────────────────────────────────────────────────
# `make dev` already injects API_URL + NEXT_PUBLIC_ENGINE_URL. Override here only
# if you run the web app outside of `make dev`.
# NEXT_PUBLIC_ENGINE_URL=http://localhost:8787
# API_URL=http://localhost:8787

# Set to 1 to use mocked data instead of the live engine.
NEXT_PUBLIC_USE_MOCK=
